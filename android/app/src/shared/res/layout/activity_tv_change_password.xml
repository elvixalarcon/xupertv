<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tv_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cambiar contraseña"
        android:textColor="@color/tv_text"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_change_pass_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="28dp"
        android:textColor="@color/tv_text_dim"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/tv_change_pass_current"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:background="@color/tv_card"
        android:hint="Contraseña actual"
        android:inputType="textPassword"
        android:padding="16dp"
        android:textColor="@color/tv_text"
        android:textColorHint="@color/tv_text_dim" />

    <EditText
        android:id="@+id/tv_change_pass_new"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@color/tv_card"
        android:hint="Nueva contraseña"
        android:inputType="textPassword"
        android:padding="16dp"
        android:textColor="@color/tv_text"
        android:textColorHint="@color/tv_text_dim" />

    <EditText
        android:id="@+id/tv_change_pass_confirm"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@color/tv_card"
        android:hint="Confirmar nueva contraseña"
        android:inputType="textPassword"
        android:padding="16dp"
        android:textColor="@color/tv_text"
        android:textColorHint="@color/tv_text_dim" />

    <Button
        android:id="@+id/tv_change_pass_save"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/tv_accent"
        android:text="Guardar"
        android:textColor="@color/tv_text"
        android:textStyle="bold" />

    <Button
        android:id="@+id/tv_change_pass_cancel"
        style="@style/TvMenuButton"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Cancelar" />

    <TextView
        android:id="@+id/tv_change_pass_error"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="#ff4757"
        android:textSize="14sp" />
</LinearLayout>
