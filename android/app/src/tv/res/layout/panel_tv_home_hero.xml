<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tv_home_hero_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/tv_bg"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingTop="0dp"
    android:paddingEnd="0dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="268dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/tv_hero_slide_wrap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="1dp"
            android:layout_weight="1"
            android:background="@drawable/tv_hero_selector"
            android:clipChildren="false"
            android:focusable="true"
            android:padding="0dp">

            <ImageView
                android:id="@+id/tv_hero_slide_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tv_card"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:id="@+id/tv_hero_dots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/tv_hero_slide_title"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/tv_hero_fixed_wrap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/tv_hero_selector"
            android:clipChildren="false"
            android:focusable="true"
            android:padding="0dp">

            <ImageView
                android:id="@+id/tv_hero_fixed_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/tv_card"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="138dp"
        android:layout_marginTop="1dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">

        <include
            android:id="@+id/tv_hero_tile_0"
            layout="@layout/item_tv_hero_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="1dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/tv_hero_tile_1"
            layout="@layout/item_tv_hero_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="1dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/tv_hero_tile_2"
            layout="@layout/item_tv_hero_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="1dp"
            android:layout_weight="1" />

        <include
            android:id="@+id/tv_hero_tile_3"
            layout="@layout/item_tv_hero_tile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>
