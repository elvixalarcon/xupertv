<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="420dp"
    android:layout_height="wrap_content"
    android:background="@drawable/tv_update_dialog_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="28dp"
    android:paddingEnd="28dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/tv_update_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/update_notification_title"
        android:textColor="@color/tv_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_update_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/tv_text_dim"
        android:textSize="15sp" />

    <Button
        android:id="@+id/tv_update_download"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:backgroundTint="@color/tv_accent"
        android:focusable="true"
        android:minHeight="48dp"
        android:text="@string/update_action_download"
        android:textColor="@color/tv_text"
        android:textSize="16sp" />

    <Button
        android:id="@+id/tv_update_later"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="#33445566"
        android:focusable="true"
        android:minHeight="44dp"
        android:text="@string/update_later"
        android:textColor="@color/tv_text_dim"
        android:textSize="14sp" />
</LinearLayout>
