<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/mobile_avatar_box"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/mobile_avatar_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/mobile_poster_bg"
            android:gravity="center"
            android:textColor="@color/mobile_text"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mobile_avatar_kids"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/mobile_btn_accent"
            android:paddingStart="6dp"
            android:paddingTop="2dp"
            android:paddingEnd="6dp"
            android:paddingBottom="2dp"
            android:text="KIDS"
            android:textColor="#000000"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/mobile_avatar_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/mobile_muted"
        android:textSize="14sp" />
</LinearLayout>
