<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobile_bg"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mobile_profile_title"
        android:textColor="@color/mobile_text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mobile_profile_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/mobile_muted"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/mobile_profile_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/mobile_switch_profile"
        android:textColor="@color/mobile_accent"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/mobile_profile_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="@string/mobile_change_password"
        android:textColor="@color/mobile_accent"
        android:textSize="15sp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/mobile_profile_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/mobile_card"
        app:tabIndicatorColor="@color/mobile_accent"
        app:tabIndicatorHeight="0dp"
        app:tabMode="fixed"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="#000000"
        app:tabTextColor="@color/mobile_text" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/mobile_profile_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/mobile_profile_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:text="@string/mobile_logout"
        android:textColor="#FF453A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/mobile_profile_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/mobile_accent"
        android:visibility="gone" />
</LinearLayout>
