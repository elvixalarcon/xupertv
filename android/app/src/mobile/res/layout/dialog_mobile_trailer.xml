<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/mobile_bg"
    android:padding="8dp">

    <androidx.media3.ui.PlayerView
        android:id="@+id/mobile_trailer_player"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:resize_mode="fit"
        app:use_controller="true" />

    <ImageButton
        android:id="@+id/mobile_trailer_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:background="@drawable/mobile_mute_btn_bg"
        android:contentDescription="@string/mobile_detail_back"
        android:padding="8dp"
        android:src="@drawable/ic_mobile_back"
        app:tint="@color/mobile_text" />
</FrameLayout>
