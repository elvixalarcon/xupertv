<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mobile_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/mobile_home_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/mobile_bg"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mobile_login_title"
                android:textColor="@color/mobile_accent"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/mobile_home_search"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/mobile_poster_bg"
                android:hint="@string/mobile_search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/mobile_text"
                android:textColorHint="@color/mobile_muted"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/mobile_home_profile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/mobile_tab_profile"
                android:padding="4dp"
                android:src="@drawable/ic_tv_profile"
                app:tint="@color/mobile_muted" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <FrameLayout
                android:id="@+id/mobile_home_hero"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/mobile_hero_frame"
                android:clipToOutline="true"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/mobile_home_hero_img"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop" />

                <androidx.media3.ui.PlayerView
                    android:id="@+id/mobile_home_hero_player"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    app:resize_mode="zoom"
                    app:show_buffering="when_playing"
                    app:surface_type="texture_view"
                    app:use_controller="false" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/mobile_hero_scrim" />

                <ImageButton
                    android:id="@+id/mobile_home_hero_mute"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/mobile_mute_btn_bg"
                    android:contentDescription="Silenciar tráiler"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_mobile_volume_off"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/mobile_home_hero_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:padding="16dp"
                    android:textAllCaps="true"
                    android:textColor="@color/mobile_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/mobile_home_hero_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:orientation="horizontal" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/mobile_home_worldcup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp">

                    <View
                        android:id="@+id/mobile_home_worldcup_dot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/mobile_live_dot"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/mobile_home_worldcup_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="En vivo y próximamente"
                        android:textColor="@color/mobile_text"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mobile_home_worldcup_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/mobile_home_chips_scroll"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/mobile_home_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mobile_home_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/mobile_home_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/mobile_accent"
        android:visibility="gone" />

    <TextView
        android:id="@+id/mobile_home_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/mobile_empty"
        android:textColor="@color/mobile_muted"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
