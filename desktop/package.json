{
  "name": "vixtv-desktop",
  "productName": "Vix TV",
  "version": "1.0.0",
  "description": "Vix TV para Windows — cliente de escritorio",
  "main": "electron/main.js",
  "author": "Vix TV",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "tv.vix.desktop",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "VixTV-Setup-${version}.${ext}",
      "publisherName": "Vix TV"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vix TV"
    },
    "portable": {
      "artifactName": "VixTV-Portable-${version}.${ext}"
    }
  }
}
